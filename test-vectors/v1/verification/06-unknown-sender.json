  "spec_references": [
    "spec/v1/10-encrypt-decrypt.md#10.2",
    "spec/v1/10-encrypt-decrypt.md#10.3.5"
  ],
  "cases": [
    {
      "id": "v1-ver-unknown-sender-001",
      "description": "Sender's key not present in consumer's contacts.",
      "inputs": {
        "wire": "PLAINCLOAK:v1:BR:",
        "recipient_priv_pem_path": "test-vectors/v1/fixtures/keys/alice-rsa2048-priv.pem",
        "trusted_senders": []
      },
      "expected": {
        "outcome": "unknown-sender",
        "plaintext": "Unknown-sender test."
      }
    }
  ]
