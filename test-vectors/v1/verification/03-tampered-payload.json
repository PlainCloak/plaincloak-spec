{
  "version": "v1",
  "kind": "verification",
  "category": "tampered-payload",
  "description": "A wire message whose payload was modified after signing. Decryption MUST fail before signature verification is attempted, per spec/v1/10-encrypt-decrypt.md section 10.2 step 2.",
  "spec_references": [
    "spec/v1/10-encrypt-decrypt.md#10.2",
    "spec/v1/10-encrypt-decrypt.md#10.3.3"
  ],
  "cases": [
    {
      "id": "v1-ver-tampered-payload-001",
      "description": "Last byte of OAEP ciphertext flipped after signing.",
      "inputs": {
        "wire": "PLAINCLOAK:v1:BR:",
        "recipient_priv_pem_path": "test-vectors/v1/fixtures/keys/bob-rsa4096-priv.pem",
        "trusted_senders": [
          {
            "key_hash": "1bf44bedd390cd114d5511c53286330f29c9fe70a4ab86118731860898ef88da",
            "public_key_pem_path": "test-vectors/v1/fixtures/keys/alice-rsa2048-pub.pem"
          }
        ]
      },
      "expected": {
        "outcome": "decryption-failed",
        "plaintext_present": false
      }
    }
  ]
