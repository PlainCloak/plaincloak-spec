{
  "version": "v1",
  "kind": "verification",
  "category": "hybrid-tampered-tag",
  "description": "A hybrid wire message with the last byte of the AEAD tag flipped after signing. The AES-GCM tag check MUST fail, surfacing decryption-failed (Section 10.2 step 2).",
  "spec_references": [
    "spec/v1/08-crypto-suites.md#8.10.5",
    "spec/v1/10-encrypt-decrypt.md#10.3.3"
  ],
  "cases": [
    {
      "id": "v1-ver-hybrid-tampered-tag-001",
      "description": "Last byte of the 16-byte AEAD tag flipped after signing.",
      "inputs": {
        "wire": "PLAINCLOAK:v1:BR:",
        "recipient_priv_pem_path": "test-vectors/v1/fixtures/keys/bob-rsa4096-priv.pem",
        "trusted_senders": [
          {
            "key_hash": "1bf44bedd390cd114d5511c53286330f29c9fe70a4ab86118731860898ef88da",
            "public_key_pem_path": "test-vectors/v1/fixtures/keys/alice-rsa2048-pub.pem"
          }
        ]
      },
      "expected": {
        "outcome": "decryption-failed",
        "plaintext_present": false
      }
    }
  ]
}
