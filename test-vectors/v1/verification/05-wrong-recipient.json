{
  "version": "v1",
  "kind": "verification",
  "category": "wrong-recipient",
  "description": "Ciphertext encrypted to a key that the consumer does not hold. Consumer MUST NOT attempt decryption with any other key; outcome is wrong-recipient per spec/v1/10-encrypt-decrypt.md section 10.3.2.",
  "spec_references": [
    "spec/v1/10-encrypt-decrypt.md#10.2",
    "spec/v1/10-encrypt-decrypt.md#10.3.2"
  ],
  "cases": [
    {
      "id": "v1-ver-wrong-recipient-001",
      "description": "Encrypted to bob-rsa4096; consumer holds only alice-rsa2048.",
      "inputs": {
        "wire": "PLAINCLOAK:v1:BR:",
        "recipient_priv_pem_path": "test-vectors/v1/fixtures/keys/alice-rsa2048-priv.pem",
        "trusted_senders": []
      },
      "expected": {
        "outcome": "wrong-recipient",
        "plaintext_present": false
      }
    }
  ]
}
