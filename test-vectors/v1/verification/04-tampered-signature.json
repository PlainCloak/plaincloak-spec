{
  "version": "v1",
  "kind": "verification",
  "category": "tampered-signature",
  "description": "A wire message whose signature was modified after signing. Decryption succeeds but signature verification MUST fail. Plaintext MUST still be surfaced with the signature-invalid outcome per spec/v1/10-encrypt-decrypt.md section 10.3.4.",
  "spec_references": [
    "spec/v1/10-encrypt-decrypt.md#10.2",
    "spec/v1/10-encrypt-decrypt.md#10.3.4"
  ],
  "cases": [
    {
      "id": "v1-ver-tampered-signature-001",
      "description": "Last byte of PSS signature flipped after signing.",
      "inputs": {
        "wire": "PLAINCLOAK:v1:BR:",
        "recipient_priv_pem_path": "test-vectors/v1/fixtures/keys/bob-rsa4096-priv.pem",
        "trusted_senders": [
          {
            "key_hash": "1bf44bedd390cd114d5511c53286330f29c9fe70a4ab86118731860898ef88da",
            "public_key_pem_path": "test-vectors/v1/fixtures/keys/alice-rsa2048-pub.pem"
          }
        ]
      },
      "expected": {
        "outcome": "signature-invalid",
        "plaintext": "Tampered-signature test."
      }
    }
  ]
}
